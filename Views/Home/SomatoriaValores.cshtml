@model List<RegistrosFinanceiros>

<div class="row mt-5">
    <a asp-action="index" class="btn btn-info w-100 mb-5">Voltar</a>

    
    <div class="col-md-4">

        <h2>Ganhos</h2>

        <table class="table table-bordered mt-2">

            
            <thead class="table-success">
                <tr>
                    <th>Categoria</th>
                    <th>Transação</th>
                    <th>Valor</th>
                </tr>
            </thead>
            <tbody>

                <!-- <-- Exibe os ganhos --> 
                @if (Model.Count() > 0)
                {
                    @* <-- Filtra os ganhos e exibe na tabela --> *@
                    @foreach (var ganho in Model.Where(x => x.TransacaoNome == "Ganho").ToList())
                    {
                        <tr>
                            <td>@ganho.CategoriaNome</td>
                            <td>@ganho.TransacaoNome</td>
                            <td>R$ @ganho.ValorCategoria.ToString("F")</td>
                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

    <div class="col-md-4">

        <h2>Gastos</h2>

        <table class="table table-bordered mt-2">

            <thead class="table-danger">
                <tr>
                    <th>Categoria</th>
                    <th>Transação</th>
                    <th>Valor</th>
                </tr>
            </thead>
            <tbody>

                @* <-- Exibe os gastos --> *@
                @if (Model.Count() > 0)
                {
                    @foreach (var gasto in Model.Where(x => x.TransacaoNome == "Gasto").ToList())
                    {
                        <tr>
                            <td>@gasto.CategoriaNome</td>
                            <td>@gasto.TransacaoNome</td>
                            <td>R$ @gasto.ValorCategoria.ToString("F")</td>
                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>

    <div class="col-md-4">

        <h2>Totais</h2>

        <table class="table table-bordered mt-2">

            <thead class="table-dark">
                <tr>
                    <th>Gastos</th>
                    <th>Ganhos</th>
                    <th>Diferença</th>
                </tr>
            </thead>
            <tbody>

                 @* <-- Exibe os totais de gastos, ganhos e diferença --> *@

                @if (Model.Count() > 0)
                {
                    @* <-- Exibe os totais usando o primeiro registro, pois todos os registros possuem os mesmos totais --> *@
                   <tr>
                      <td>R$ @Model.First().Gastos.ToString("F")</td>
                      <td>R$ @Model.First().Ganhos.ToString("F")</td>
                      <td>R$ @Model.First().Diferenca.ToString("F")</td>
                   </tr>
                }

            </tbody>

        </table>

    </div>

</div>

